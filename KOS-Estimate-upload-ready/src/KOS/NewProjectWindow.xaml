<Window x:Class="KOS.NewProjectWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="새 현장 프로젝트" Width="520" Height="480" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
 <Grid Margin="24">
  <Grid.RowDefinitions>
   <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
   <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
  </Grid.RowDefinitions>
  <TextBlock Text="새 현장 프로젝트" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
  <StackPanel Grid.Row="1"><TextBlock Text="프로젝트명 *"/><TextBox x:Name="NameBox" Height="34" Margin="0,6,0,12"/></StackPanel>
  <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
   <StackPanel Margin="0,0,6,0"><TextBlock Text="현장 주소"/><TextBox x:Name="AddressBox" Height="34" Margin="0,6,0,12"/></StackPanel>
   <StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="발주처/고객"/><TextBox x:Name="ClientBox" Height="34" Margin="0,6,0,12"/></StackPanel>
  </Grid>
  <StackPanel Grid.Row="3"><TextBlock Text="공사 구분"/><TextBox x:Name="WorkTypeBox" Height="34" Margin="0,6,0,12"/></StackPanel>
  <StackPanel Grid.Row="4"><TextBlock Text="메모"/><TextBox x:Name="NoteBox" AcceptsReturn="True" TextWrapping="Wrap" Height="110" Margin="0,6,0,12"/></StackPanel>
  <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
   <Button Content="취소" Width="90" Click="Cancel_Click"/>
   <Button Content="프로젝트 만들기" Width="140" Background="#2563EB" Foreground="White" Click="Create_Click"/>
  </StackPanel>
 </Grid>
</Window>
