<Window x:Class="KOS.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="KOS" Width="1480" Height="900" MinWidth="1180" MinHeight="720"
 Background="{StaticResource CanvasBrush}" WindowStartupLocation="CenterScreen">
 <Grid>
  <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
  <Border Background="{StaticResource SidebarBrush}">
   <DockPanel>
    <StackPanel DockPanel.Dock="Top">
     <TextBlock Text="KOS" Foreground="White" FontSize="30" FontWeight="Bold" Margin="24,22,20,24"/>
     <Button x:Name="ProjectsNav" Content="프로젝트" Tag="Projects" Click="Nav_Click" Background="#1F2937" Foreground="White" HorizontalContentAlignment="Left"/>
     <Button Content="개요" Tag="Overview" Click="Nav_Click" Background="Transparent" Foreground="#D1D5DB" HorizontalContentAlignment="Left"/>
     <Button Content="도면" Tag="Drawings" Click="Nav_Click" Background="Transparent" Foreground="#D1D5DB" HorizontalContentAlignment="Left"/>
     <Button Content="물량산출" Tag="Takeoff" Click="Nav_Click" Background="Transparent" Foreground="#D1D5DB" HorizontalContentAlignment="Left"/>
     <Button Content="공내역서" Tag="Estimate" Click="Nav_Click" Background="Transparent" Foreground="#D1D5DB" HorizontalContentAlignment="Left"/>
     <Button Content="출력" Tag="Output" Click="Nav_Click" Background="Transparent" Foreground="#D1D5DB" HorizontalContentAlignment="Left"/>
    </StackPanel>
    <TextBlock DockPanel.Dock="Bottom" Text="KOS 0.1.0 통합 테스트" Foreground="#9CA3AF" Margin="20,12"/>
   </DockPanel>
  </Border>

  <Grid Grid.Column="1">
   <Grid.RowDefinitions><RowDefinition Height="72"/><RowDefinition Height="*"/><RowDefinition Height="34"/></Grid.RowDefinitions>
   <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
    <Grid Margin="22,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
     <StackPanel VerticalAlignment="Center"><TextBlock x:Name="HeaderTitle" Text="현장 프로젝트" FontSize="21" FontWeight="Bold"/><TextBlock x:Name="HeaderSub" Text="프로젝트를 선택하거나 새로 만드세요." Foreground="#6B7280"/></StackPanel>
     <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
      <Button Content="프로젝트 폴더" Click="OpenProjectFolder_Click"/>
      <Button Content="저장" Click="Save_Click"/>
      <Button Content="＋ 새 프로젝트" Background="#2563EB" Foreground="White" Click="NewProject_Click"/>
     </StackPanel>
    </Grid>
   </Border>

   <Grid Grid.Row="1" Margin="18">
    <Grid x:Name="ProjectsPage">
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <DockPanel Margin="0,0,0,12"><TextBlock Text="최근 프로젝트" FontSize="24" FontWeight="Bold"/><TextBox x:Name="ProjectSearch" DockPanel.Dock="Right" Width="280" Height="34" TextChanged="ProjectSearch_TextChanged"/></DockPanel>
     <ListBox Grid.Row="1" x:Name="ProjectList" ItemsSource="{Binding Projects}" MouseDoubleClick="ProjectList_DoubleClick" BorderThickness="0" Background="Transparent">
      <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ListBox.ItemsPanel>
      <ListBox.ItemTemplate><DataTemplate>
       <Border Width="330" Height="155" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Margin="0,0,12,12" Padding="18">
        <StackPanel><TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"/><TextBlock Text="{Binding Address}" Margin="0,8,0,2" Foreground="#4B5563"/><TextBlock Text="{Binding Client}" Foreground="#6B7280"/><TextBlock Text="{Binding Summary}" Margin="0,16,0,0" Foreground="#2563EB"/></StackPanel>
       </Border>
      </DataTemplate></ListBox.ItemTemplate>
     </ListBox>
    </Grid>

    <Grid x:Name="OverviewPage" Visibility="Collapsed">
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <TextBlock Text="프로젝트 개요" FontSize="24" FontWeight="Bold"/>
     <UniformGrid Grid.Row="1" Columns="5" Margin="0,16,0,16">
      <Border Style="{x:Null}" Background="White" CornerRadius="8" Padding="16" Margin="0,0,10,0"><StackPanel><TextBlock Text="도면"/><TextBlock x:Name="KpiDrawings" FontSize="28" FontWeight="Bold"/></StackPanel></Border>
      <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,10,0"><StackPanel><TextBlock Text="분석 완료"/><TextBlock x:Name="KpiAnalyzed" FontSize="28" FontWeight="Bold"/></StackPanel></Border>
      <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,10,0"><StackPanel><TextBlock Text="공내역 행"/><TextBlock x:Name="KpiEstimates" FontSize="28" FontWeight="Bold"/></StackPanel></Border>
      <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,10,0"><StackPanel><TextBlock Text="단가 확정률"/><TextBlock x:Name="KpiPriceRate" FontSize="28" FontWeight="Bold"/></StackPanel></Border>
      <Border Background="White" CornerRadius="8" Padding="16"><StackPanel><TextBlock Text="예상 공사비"/><TextBlock x:Name="KpiAmount" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
     </UniformGrid>
     <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20"><StackPanel><TextBlock Text="다음 작업" FontWeight="Bold" FontSize="17"/><TextBlock x:Name="NextActionText" Margin="0,12,0,0" FontSize="15"/></StackPanel></Border>
    </Grid>

    <Grid x:Name="DrawingsPage" Visibility="Collapsed">
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <DockPanel Margin="0,0,0,10">
      <StackPanel Orientation="Horizontal">
       <Button Content="＋ CAD 파일" Background="#2563EB" Foreground="White" Click="AddFiles_Click"/>
       <Button Content="＋ CAD 폴더" Click="AddFolder_Click"/>
       <Button Content="선택 삭제" Click="RemoveDrawing_Click"/>
       <Button Content="▶ 전체 분석" Background="#059669" Foreground="White" Click="Analyze_Click"/>
       <Button Content="분석 취소" Click="CancelAnalysis_Click"/>
      </StackPanel>
      <ProgressBar x:Name="AnalysisProgress" Width="240" Height="18" DockPanel.Dock="Right"/>
     </DockPanel>
     <DataGrid Grid.Row="1" x:Name="DrawingGrid" ItemsSource="{Binding ActiveProject.Drawings}">
      <DataGrid.Columns>
       <DataGridTextColumn Header="파일명" Binding="{Binding FileName}" Width="2*"/>
       <DataGridTextColumn Header="도면 구분" Binding="{Binding DrawingType}" Width="130"/>
       <DataGridTextColumn Header="층" Binding="{Binding Level}" Width="90"/>
       <DataGridTextColumn Header="구역" Binding="{Binding Zone}" Width="120"/>
       <DataGridTextColumn Header="객체 수" Binding="{Binding ObjectCount, StringFormat=N0}" Width="100"/>
       <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100"/>
       <DataGridTextColumn Header="오류" Binding="{Binding Error}" Width="2*"/>
      </DataGrid.Columns>
     </DataGrid>
    </Grid>

    <Grid x:Name="TakeoffPage" Visibility="Collapsed">
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <DockPanel Margin="0,0,0,10"><TextBlock x:Name="TakeoffSummary" FontSize="17" FontWeight="Bold"/><Button DockPanel.Dock="Right" Content="검토 필요만" Click="FilterReview_Click"/></DockPanel>
     <DataGrid Grid.Row="1" x:Name="TakeoffGrid" ItemsSource="{Binding ActiveProject.Estimates}" IsReadOnly="True">
      <DataGrid.Columns>
       <DataGridTextColumn Header="공종" Binding="{Binding Trade}" Width="120"/>
       <DataGridTextColumn Header="품명" Binding="{Binding ItemName}" Width="180"/>
       <DataGridTextColumn Header="규격" Binding="{Binding Specification}" Width="150"/>
       <DataGridTextColumn Header="층" Binding="{Binding Level}" Width="80"/>
       <DataGridTextColumn Header="구역" Binding="{Binding Zone}" Width="100"/>
       <DataGridTextColumn Header="단위" Binding="{Binding Unit}" Width="65"/>
       <DataGridTextColumn Header="수량" Binding="{Binding Quantity, StringFormat=N4}" Width="100"/>
       <DataGridTextColumn Header="산출식" Binding="{Binding Formula}" Width="180"/>
       <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="140"/>
      </DataGrid.Columns>
     </DataGrid>
    </Grid>

    <Grid x:Name="EstimatePage" Visibility="Collapsed">
     <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="340"/></Grid.ColumnDefinitions>
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
      <Button Content="단가 자동 채우기" Background="#2563EB" Foreground="White" Click="AutoPrice_Click"/>
      <Button Content="선택 행 삭제" Click="RemoveEstimate_Click"/>
      <Button Content="검토 필요만" Click="FilterReview_Click"/>
      <TextBox x:Name="EstimateSearch" Width="260" Height="34" Margin="12,3,3,3" TextChanged="EstimateSearch_TextChanged"/>
     </StackPanel>
     <DataGrid Grid.Row="1" x:Name="EstimateGrid" ItemsSource="{Binding ActiveProject.Estimates}" SelectionChanged="EstimateGrid_SelectionChanged">
      <DataGrid.Columns>
       <DataGridCheckBoxColumn Header="선택" Binding="{Binding Selected}" Width="55"/>
       <DataGridTextColumn Header="공종" Binding="{Binding Trade}" Width="105"/>
       <DataGridTextColumn Header="공종코드" Binding="{Binding TradeCode}" Width="80"/>
       <DataGridTextColumn Header="품목코드" Binding="{Binding ItemCode}" Width="110"/>
       <DataGridTextColumn Header="품명" Binding="{Binding ItemName}" Width="170"/>
       <DataGridTextColumn Header="규격" Binding="{Binding Specification}" Width="130"/>
       <DataGridTextColumn Header="단위" Binding="{Binding Unit}" Width="60"/>
       <DataGridTextColumn Header="수량" Binding="{Binding Quantity, StringFormat=N4}" Width="90"/>
       <DataGridTextColumn Header="재료비" Binding="{Binding MaterialUnitPrice, StringFormat=N0}" Width="90"/>
       <DataGridTextColumn Header="노무비" Binding="{Binding LaborUnitPrice, StringFormat=N0}" Width="90"/>
       <DataGridTextColumn Header="경비" Binding="{Binding ExpenseUnitPrice, StringFormat=N0}" Width="90"/>
       <DataGridTextColumn Header="합계단가" Binding="{Binding TotalUnitPrice, StringFormat=N0}" Width="100" IsReadOnly="True"/>
       <DataGridTextColumn Header="합계금액" Binding="{Binding TotalAmount, StringFormat=N0}" Width="120" IsReadOnly="True"/>
       <DataGridTextColumn Header="출처" Binding="{Binding PriceSource}" Width="130"/>
       <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="130"/>
      </DataGrid.Columns>
     </DataGrid>
     <Border Grid.Column="1" Grid.RowSpan="2" Margin="12,0,0,0" Background="White" CornerRadius="8" Padding="16">
      <ScrollViewer><StackPanel>
       <TextBlock Text="선택 품목 검토" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
       <TextBlock Text="품명" FontWeight="Bold"/><TextBlock x:Name="DetailName" TextWrapping="Wrap" Margin="0,4,0,12"/>
       <TextBlock Text="산출 근거" FontWeight="Bold"/><TextBlock x:Name="DetailFormula" TextWrapping="Wrap" Margin="0,4,0,12"/>
       <TextBlock Text="원본 도면" FontWeight="Bold"/><TextBlock x:Name="DetailDrawing" TextWrapping="Wrap" Margin="0,4,0,12"/>
       <TextBlock Text="레이어 / Handle" FontWeight="Bold"/><TextBlock x:Name="DetailSource" TextWrapping="Wrap" Margin="0,4,0,12"/>
       <TextBlock Text="가정·검토사유" FontWeight="Bold"/><TextBlock x:Name="DetailAssumption" TextWrapping="Wrap" Margin="0,4,0,12"/>
       <TextBlock Text="단가 출처" FontWeight="Bold"/><TextBlock x:Name="DetailPrice" TextWrapping="Wrap" Margin="0,4,0,12"/>
      </StackPanel></ScrollViewer>
     </Border>
    </Grid>

    <Grid x:Name="OutputPage" Visibility="Collapsed">
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <TextBlock Text="출력" FontSize="24" FontWeight="Bold"/>
     <UniformGrid Grid.Row="1" Columns="3" Margin="0,18,0,0">
      <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,12,0"><StackPanel><TextBlock Text="표준 공내역서" FontSize="18" FontWeight="Bold"/><TextBlock Text="공종·코드·품명·규격·수량·재료비·노무비·경비" TextWrapping="Wrap" Margin="0,10,0,20"/><Button Content="Excel 저장" Background="#2563EB" Foreground="White" Click="ExportExcel_Click"/></StackPanel></Border>
      <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,12,0"><StackPanel><TextBlock Text="프로젝트 폴더" FontSize="18" FontWeight="Bold"/><TextBlock Text="도면·분석·내역·출력을 현장별로 분리 보관합니다." TextWrapping="Wrap" Margin="0,10,0,20"/><Button Content="폴더 열기" Click="OpenProjectFolder_Click"/></StackPanel></Border>
      <Border Background="White" CornerRadius="8" Padding="20"><StackPanel><TextBlock Text="검토 목록" FontSize="18" FontWeight="Bold"/><TextBlock Text="단가 미확정 및 품목·규격 확인이 필요한 항목을 확인합니다." TextWrapping="Wrap" Margin="0,10,0,20"/><Button Content="검토 필요만 보기" Click="FilterReview_Click"/></StackPanel></Border>
     </UniformGrid>
    </Grid>
   </Grid>

   <Border Grid.Row="2" Background="#E5E7EB"><TextBlock x:Name="StatusText" Margin="12,7" Text="준비"/></Border>
  </Grid>
 </Grid>
</Window>
